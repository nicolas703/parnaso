---
import { getGroupStageMatches } from "../lib/footballData";
import { savePlayerPredictions } from "../lib/predictionsStore";
import { getCountryDisplay } from "../lib/countries";
import { formatMatchDate, formatMatchName, formatRound } from "../lib/quiniela";
import type { Match, Prediction } from "../lib/types";

export const prerender = false;

const payload = await getGroupStageMatches();
const formValues = new Map<string, string>();
let playerName = "";
let statusMessage = "";
let errorMessage = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  playerName = getFormValue(formData, "name");

  for (const [key, value] of formData.entries()) {
    if (typeof value === "string") {
      formValues.set(key, value);
    }
  }

  try {
    const predictions = buildPredictions(formData, payload.matches);
    const saveResult = await savePlayerPredictions(playerName, predictions);
    statusMessage =
      saveResult === "created"
        ? `${playerName} agregado con ${predictions.length} predicciones.`
        : `${playerName} actualizado con ${predictions.length} predicciones.`;
  } catch (error) {
    errorMessage = error instanceof Error ? error.message : "No se pudo guardar la prediccion.";
  }
}

function buildPredictions(formData: FormData, matches: Match[]): Prediction[] {
  const name = getFormValue(formData, "name");

  if (!name) {
    throw new Error("Falta el nombre.");
  }

  return matches.map((match) => {
    const homeScore = parseScore(getFormValue(formData, `home-${match.id}`), match);
    const awayScore = parseScore(getFormValue(formData, `away-${match.id}`), match);

    return {
      matchId: match.id,
      matchKey: match.key,
      homeScore,
      awayScore
    };
  });
}

function getFormValue(formData: FormData, key: string): string {
  const value = formData.get(key);
  return typeof value === "string" ? value.trim() : "";
}

function parseScore(value: string, match: Match): number {
  if (!/^\d+$/.test(value)) {
    throw new Error(`Falta un marcador valido para ${formatMatchName(match)}.`);
  }

  const score = Number(value);

  if (score > 99) {
    throw new Error(`El marcador de ${formatMatchName(match)} es demasiado alto.`);
  }

  return score;
}

function inputValue(match: Match, side: "home" | "away") {
  return formValues.get(`${side}-${match.id}`) ?? "";
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Agregar predicciones</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f7f2;
        --surface: #ffffff;
        --surface-muted: #f0f2ed;
        --ink: #171914;
        --muted: #60675b;
        --line: #dfe4d8;
        --green: #188452;
        --green-soft: #e5f6ec;
        --red: #c4382c;
        --red-soft: #ffe3df;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
      }

      .shell {
        width: min(960px, 100%);
        margin: 0 auto;
        padding: 20px;
      }

      .topbar {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: end;
        gap: 12px;
        padding: 10px 0 18px;
      }

      .eyebrow {
        margin: 0 0 6px;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 850;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: 1.8rem;
        line-height: 1.08;
        letter-spacing: 0;
      }

      a,
      button {
        border-radius: 8px;
        font: inherit;
      }

      .back-link {
        border: 1px solid var(--line);
        background: var(--surface);
        color: var(--ink);
        padding: 9px 12px;
        text-decoration: none;
        font-weight: 800;
      }

      form {
        display: grid;
        gap: 12px;
      }

      .player-field,
      .match-row,
      .message {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
      }

      .player-field {
        display: grid;
        gap: 7px;
        padding: 12px;
      }

      label,
      .match-meta {
        color: var(--muted);
        font-size: 0.75rem;
        font-weight: 850;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      input {
        width: 100%;
        min-height: 42px;
        border: 1px solid #cad3c4;
        border-radius: 8px;
        background: #fbfcf8;
        color: var(--ink);
        font: inherit;
        font-weight: 750;
        padding: 9px 10px;
      }

      input:focus {
        border-color: #6aa7ff;
        outline: 3px solid #d8eaff;
      }

      .matches {
        display: grid;
        gap: 8px;
      }

      .match-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 76px 76px;
        align-items: center;
        gap: 10px;
        padding: 10px;
      }

      .match-title {
        display: block;
        margin-bottom: 4px;
        overflow-wrap: anywhere;
        font-weight: 850;
      }

      .score-field {
        display: grid;
        gap: 5px;
      }

      .score-field label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        text-align: center;
      }

      .country-flag {
        flex: 0 0 22px;
        width: 22px;
        height: 22px;
        border: 1px solid var(--line);
        border-radius: 50%;
        background: #eef2ea;
        object-fit: contain;
        padding: 2px;
      }

      .score-country {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .score-field input {
        text-align: center;
      }

      .actions {
        position: sticky;
        bottom: 0;
        display: flex;
        justify-content: end;
        gap: 8px;
        border-top: 1px solid var(--line);
        background: color-mix(in srgb, var(--bg) 94%, transparent);
        padding: 12px 0 2px;
      }

      button {
        min-height: 44px;
        border: 1px solid #12633d;
        background: var(--green);
        color: #ffffff;
        cursor: pointer;
        font-weight: 850;
        padding: 10px 14px;
      }

      .message {
        padding: 10px 12px;
        font-weight: 750;
      }

      .message.success {
        border-color: #8fcba9;
        background: var(--green-soft);
        color: var(--green);
      }

      .message.error {
        border-color: #eca098;
        background: var(--red-soft);
        color: var(--red);
      }

      @media (max-width: 640px) {
        .shell {
          padding: 14px;
        }

        .topbar {
          grid-template-columns: 1fr;
        }

        h1 {
          font-size: 1.55rem;
        }

        .back-link {
          width: fit-content;
        }

        .match-row {
          grid-template-columns: minmax(0, 1fr) 64px 64px;
          gap: 8px;
        }

        .score-country {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div>
          <p class="eyebrow">{payload.competition.name} {payload.season}</p>
          <h1>Agregar predicciones</h1>
        </div>
        <a class="back-link" href="/">Volver</a>
      </header>

      {statusMessage && <p class="message success">{statusMessage}</p>}
      {errorMessage && <p class="message error">{errorMessage}</p>}

      <form method="post" action="/add">
        <div class="player-field">
          <label for="name">Nombre</label>
          <input
            id="name"
            name="name"
            autocomplete="name"
            value={playerName}
            maxlength="80"
            required
          />
        </div>

        <section class="matches" aria-label="Predicciones por partido">
          {
            payload.matches.map((match) => {
              const homeCountry = getCountryDisplay(match.homeTeam);
              const awayCountry = getCountryDisplay(match.awayTeam);

              return (
                <div class="match-row">
                  <div>
                    <span class="match-title">{formatMatchName(match)}</span>
                    <span class="match-meta">
                      {formatRound(match)} - {formatMatchDate(match)}
                    </span>
                  </div>
                  <div class="score-field">
                    <label for={`home-${match.id}`}>
                      {homeCountry.flagUrl && (
                        <img
                          class="country-flag"
                          src={homeCountry.flagUrl}
                          alt=""
                          width="22"
                          height="22"
                          loading="lazy"
                        />
                      )}
                      <span class="score-country">{homeCountry.name}</span>
                    </label>
                    <input
                      id={`home-${match.id}`}
                      name={`home-${match.id}`}
                      type="number"
                      inputmode="numeric"
                      min="0"
                      max="99"
                      value={inputValue(match, "home")}
                      aria-label={`Marcador de ${homeCountry.name}`}
                      required
                    />
                  </div>
                  <div class="score-field">
                    <label for={`away-${match.id}`}>
                      {awayCountry.flagUrl && (
                        <img
                          class="country-flag"
                          src={awayCountry.flagUrl}
                          alt=""
                          width="22"
                          height="22"
                          loading="lazy"
                        />
                      )}
                      <span class="score-country">{awayCountry.name}</span>
                    </label>
                    <input
                      id={`away-${match.id}`}
                      name={`away-${match.id}`}
                      type="number"
                      inputmode="numeric"
                      min="0"
                      max="99"
                      value={inputValue(match, "away")}
                      aria-label={`Marcador de ${awayCountry.name}`}
                      required
                    />
                  </div>
                </div>
              );
            })
          }
        </section>

        <div class="actions">
          <button type="submit">Guardar</button>
        </div>
      </form>
    </main>
  </body>
</html>
